# Required
OP_API_KEY=op_live_...

# Strongly recommended / required outside local insecure dev mode
OP_WEBHOOK_SECRET=replace-with-op-webhook-secret
OP_ALLOWED_NUMBERS=+14155551234

# Optional
OP_HOME_CHANNEL=+14155551234
OP_WEBHOOK_HOST=127.0.0.1
OP_WEBHOOK_PORT=8645
